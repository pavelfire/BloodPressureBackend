# Local dev (go run ./cmd/api)
DATABASE_URL=postgres://bp:bp@localhost:5432/bloodpressure?sslmode=disable
JWT_SECRET=dev-secret-change-in-prod
PORT=8080
CORS_ORIGIN=*
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# Production (docker compose -f docker-compose.prod.yml --env-file .env)
POSTGRES_PASSWORD=change-me
